---
---
<header class="sticky top-0 z-50" style="background: rgba(255, 248, 240, 0.88); border-bottom: 2px solid oklch(0.93 0.020 60); backdrop-filter: blur(16px);">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <div class="w-9 h-9 rounded-xl flex items-center justify-center text-xl"
           style="background: oklch(0.60 0.18 25);">🐣</div>
      <span class="font-display font-bold text-lg leading-none" style="color: oklch(0.22 0.07 255);">
        Bright Nest<br>
        <span class="text-xs font-semibold tracking-wide" style="color: oklch(0.60 0.18 25); font-size: 0.65rem;">LEARNING</span>
      </span>
    </a>

    <!-- Nav links — desktop -->
    <div class="hidden md:flex items-center gap-6">
      <a href="#products" class="text-sm font-semibold font-body transition-colors duration-150 hover:opacity-80"
         style="color: oklch(0.38 0.04 60); font-family: var(--font-body);">Shop Packs</a>
      <a href="#how-it-works" class="text-sm font-semibold font-body transition-colors duration-150 hover:opacity-80"
         style="color: oklch(0.38 0.04 60); font-family: var(--font-body);">How It Works</a>
      <a href="#testimonials" class="text-sm font-semibold font-body transition-colors duration-150 hover:opacity-80"
         style="color: oklch(0.38 0.04 60); font-family: var(--font-body);">Reviews</a>
    </div>

    <!-- CTA -->
    <a href="#cta"
       class="shrink-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-display font-semibold transition-all duration-200 hover:scale-105 hover:shadow-md"
       style="background: oklch(0.60 0.18 25); color: white;">
      🎁 Free Sampler
    </a>

  </nav>
</header>
