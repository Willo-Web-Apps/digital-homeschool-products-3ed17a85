---
---
<header class="sticky top-0 z-50" style="background: rgba(245, 239, 224, 0.92); border-bottom: 1.5px solid #D9CEB2; backdrop-filter: blur(14px);">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <div class="w-9 h-9 rounded-xl flex items-center justify-center text-xl"
           style="background: #5C7A4E;">🌱</div>
      <span class="leading-none" style="font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.15rem; color: #2F4A35;">
        Homegrown<br>
        <span style="font-family: 'Caveat', cursive; font-weight: 400; font-size: 0.75rem; color: #C4735A; letter-spacing: 0.04em;">LEARNING</span>
      </span>
    </a>

    <!-- Nav links — desktop -->
    <div class="hidden md:flex items-center gap-6">
      <a href="/products" class="text-sm transition-colors duration-150 hover:opacity-70"
         style="color: #2F4A35; font-family: 'Lora', serif; font-weight: 400;">🛍️ Shop</a>
      <a href="#how-it-works" class="text-sm transition-colors duration-150 hover:opacity-70"
         style="color: #2F4A35; font-family: 'Lora', serif; font-weight: 400;">How It Works</a>
      <a href="#testimonials" class="text-sm transition-colors duration-150 hover:opacity-70"
         style="color: #2F4A35; font-family: 'Lora', serif; font-weight: 400;">Reviews</a>
    </div>

    <!-- CTA -->
    <a href="#cta"
       class="shrink-0 inline-flex items-center gap-1.5 px-5 py-2.5 text-sm transition-all duration-200 hover:opacity-90 hover:shadow-md"
       style="background: #5C7A4E; color: #F5EFE0; font-family: 'Caveat', cursive; font-weight: 700; font-size: 1rem; border-radius: 10px;">
      Free Sampler ✿
    </a>

  </nav>
</header>
