---
const year = new Date().getFullYear();
---
<footer style="background: oklch(0.22 0.07 255);">

  <!-- Wave top -->
  <div class="leading-none" style="line-height: 0;">
    <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:40px; display:block;">
      <path d="M0 0 C400 40 1000 0 1440 28 L1440 0 L0 0 Z" fill="oklch(0.85 0.17 85)"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid md:grid-cols-3 gap-10 pb-10 mb-10" style="border-bottom: 1px solid oklch(0.32 0.07 255);">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
               style="background: oklch(0.60 0.18 25);">🐣</div>
          <div>
            <p class="font-display font-bold text-lg leading-none" style="color: white;">Homegrown</p>
            <p class="text-xs font-semibold tracking-wider mt-0.5" style="color: oklch(0.85 0.17 85);">WHERE CURIOUS KIDS LOVE TO LEARN</p>
          </div>
        </div>
        <p class="text-sm leading-relaxed" style="color: oklch(0.70 0.04 250); font-family: var(--font-body);">
          Colorful, print-ready curriculum packs for homeschool families. Secular-inclusive, instantly downloadable, designed with joy.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-display font-semibold text-sm mb-4 tracking-wide" style="color: oklch(0.85 0.17 85);">QUICK LINKS</h4>
        <ul class="space-y-2.5">
          <li><a href="#products" class="text-sm transition-colors duration-150 hover:text-white" style="color: oklch(0.70 0.04 250); font-family: var(--font-body);">Shop All Packs</a></li>
          <li><a href="#how-it-works" class="text-sm transition-colors duration-150 hover:text-white" style="color: oklch(0.70 0.04 250); font-family: var(--font-body);">How It Works</a></li>
          <li><a href="#testimonials" class="text-sm transition-colors duration-150 hover:text-white" style="color: oklch(0.70 0.04 250); font-family: var(--font-body);">Parent Reviews</a></li>
          <li><a href="#cta" class="text-sm transition-colors duration-150 hover:text-white" style="color: oklch(0.70 0.04 250); font-family: var(--font-body);">Get Free Sampler</a></li>
        </ul>
      </div>

      <!-- Subjects -->
      <div>
        <h4 class="font-display font-semibold text-sm mb-4 tracking-wide" style="color: oklch(0.72 0.12 185);">POPULAR SUBJECTS</h4>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold font-display" style="background: oklch(0.30 0.07 255); color: oklch(0.85 0.06 250);">🌊 Science</span>
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold font-display" style="background: oklch(0.30 0.07 255); color: oklch(0.85 0.06 250);">🔤 Reading</span>
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold font-display" style="background: oklch(0.30 0.07 255); color: oklch(0.85 0.06 250);">🔢 Math</span>
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold font-display" style="background: oklch(0.30 0.07 255); color: oklch(0.85 0.06 250);">🌍 Social Studies</span>
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold font-display" style="background: oklch(0.30 0.07 255); color: oklch(0.85 0.06 250);">🎨 Art</span>
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold font-display" style="background: oklch(0.30 0.07 255); color: oklch(0.85 0.06 250);">🚀 STEM</span>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs" style="color: oklch(0.55 0.04 250); font-family: var(--font-body);">
        &copy; {year} Homegrown. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="#" class="text-xs transition-colors hover:text-white" style="color: oklch(0.55 0.04 250); font-family: var(--font-body);">Privacy Policy</a>
        <a href="#" class="text-xs transition-colors hover:text-white" style="color: oklch(0.55 0.04 250); font-family: var(--font-body);">Terms of Use</a>
        <a href="mailto:hello@brightnestlearning.com" class="text-xs transition-colors hover:text-white" style="color: oklch(0.55 0.04 250); font-family: var(--font-body);">Contact</a>
      </div>
    </div>
  </div>
</footer>
