---
const year = new Date().getFullYear();
---
<footer style="background: #2F4A35; position: relative;">

  <!-- Rolling hills SVG divider — organic, hand-drawn feel -->
  <div style="line-height: 0; margin-bottom: -2px;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:80px; display:block;">
      <!-- Back hill — lighter sage -->
      <path d="M0 60 C80 28 180 55 300 38 C420 22 500 50 620 35 C740 20 840 48 960 30 C1080 12 1180 44 1300 32 C1380 24 1420 40 1440 36 L1440 80 L0 80 Z" fill="#4A6340" opacity="0.6"/>
      <!-- Front hill — main forest green -->
      <path d="M0 72 C60 50 160 70 260 55 C360 40 440 68 560 50 C680 32 800 62 920 46 C1040 30 1140 58 1260 44 C1340 35 1400 55 1440 48 L1440 80 L0 80 Z" fill="#2F4A35"/>
      <!-- Grass tips / blades -->
      <path d="M0 80 C100 62 240 78 380 65 C520 52 660 74 800 60 C940 46 1080 70 1220 58 C1320 50 1390 68 1440 62 L1440 80 L0 80 Z" fill="#2F4A35"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid md:grid-cols-3 gap-10 pb-10 mb-10" style="border-bottom: 1px solid rgba(255,255,255,0.1);">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
               style="background: #C4735A;">🌱</div>
          <div>
            <p class="font-bold text-lg leading-none" style="font-family: 'Playfair Display', serif; color: #F5EFE0;">Homegrown</p>
            <p class="mt-1" style="font-family: 'Caveat', cursive; font-size: 1rem; color: #D4A843;">where curious kids grow</p>
          </div>
        </div>
        <p class="text-sm leading-relaxed" style="font-family: 'Lora', serif; color: rgba(245,239,224,0.65);">
          Print-ready curriculum for homeschool families. Illustrated, age-leveled, and designed with heart — instant digital downloads.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-sm mb-4 tracking-widest uppercase" style="font-family: 'Caveat', cursive; font-size: 1rem; color: #D4A843;">Quick Links</h4>
        <ul class="space-y-2.5">
          <li><a href="#products" class="text-sm transition-colors duration-150 hover:text-white" style="color: rgba(245,239,224,0.65); font-family: 'Lora', serif;">Shop All Packs</a></li>
          <li><a href="#how-it-works" class="text-sm transition-colors duration-150 hover:text-white" style="color: rgba(245,239,224,0.65); font-family: 'Lora', serif;">How It Works</a></li>
          <li><a href="#testimonials" class="text-sm transition-colors duration-150 hover:text-white" style="color: rgba(245,239,224,0.65); font-family: 'Lora', serif;">Parent Reviews</a></li>
          <li><a href="#cta" class="text-sm transition-colors duration-150 hover:text-white" style="color: rgba(245,239,224,0.65); font-family: 'Lora', serif;">Get Free Sampler</a></li>
        </ul>
      </div>

      <!-- Subjects -->
      <div>
        <h4 class="text-sm mb-4" style="font-family: 'Caveat', cursive; font-size: 1rem; color: #7BA7BC; letter-spacing: 0.04em;">Popular Subjects</h4>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 text-xs" style="background: rgba(255,255,255,0.08); color: rgba(245,239,224,0.80); font-family: 'Lora', serif; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12);">🌊 Science</span>
          <span class="px-3 py-1 text-xs" style="background: rgba(255,255,255,0.08); color: rgba(245,239,224,0.80); font-family: 'Lora', serif; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12);">🔤 Reading</span>
          <span class="px-3 py-1 text-xs" style="background: rgba(255,255,255,0.08); color: rgba(245,239,224,0.80); font-family: 'Lora', serif; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12);">🔢 Math</span>
          <span class="px-3 py-1 text-xs" style="background: rgba(255,255,255,0.08); color: rgba(245,239,224,0.80); font-family: 'Lora', serif; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12);">🌍 Social Studies</span>
          <span class="px-3 py-1 text-xs" style="background: rgba(255,255,255,0.08); color: rgba(245,239,224,0.80); font-family: 'Lora', serif; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12);">🎨 Art</span>
          <span class="px-3 py-1 text-xs" style="background: rgba(255,255,255,0.08); color: rgba(245,239,224,0.80); font-family: 'Lora', serif; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12);">🌱 Nature</span>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs" style="color: rgba(245,239,224,0.42); font-family: 'Lora', serif;">
        &copy; {year} Homegrown. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="#" class="text-xs transition-colors hover:text-white" style="color: rgba(245,239,224,0.42); font-family: 'Lora', serif;">Privacy Policy</a>
        <a href="#" class="text-xs transition-colors hover:text-white" style="color: rgba(245,239,224,0.42); font-family: 'Lora', serif;">Terms of Use</a>
        <a href="mailto:hello@homegrownlearning.com" class="text-xs transition-colors hover:text-white" style="color: rgba(245,239,224,0.42); font-family: 'Lora', serif;">Contact</a>
      </div>
    </div>
  </div>
</footer>
