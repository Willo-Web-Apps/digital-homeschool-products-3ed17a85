---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Homegrown — Whimsical Homeschool Curriculum & Printables", description = "Beautiful, print-ready homeschool curriculum packs for curious kids aged 3–12. Download illustrated unit studies, activity packs, and lesson bundles instantly." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Homegrown",
      "description": "Beautiful, print-ready homeschool curriculum packs for curious kids aged 3–12. Illustrated unit studies, activity packs, and lesson bundles — instant digital downloads.",
      "url": "https://digital-homeschool-products.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased" style="background: #F5EFE0; color: #2F4A35; font-family: 'Lora', Georgia, serif;">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
