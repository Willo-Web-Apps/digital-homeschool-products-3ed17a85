---
import Base from '../layouts/Base.astro';
---
<Base 
  title="Homegrown — Beautiful Homeschool Curriculum & Printables" 
  description="Beautiful, print-ready homeschool curriculum packs designed for curious kids aged 3–12. Download illustrated unit studies, activity packs, and lesson bundles today."
>

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Pastoral landscape: parchment sky, sage hills, paper texture
  ═══════════════════════════════════════════════════════════════════ -->
  <section class="hero-section relative overflow-hidden" style="min-height: 88vh; background: #EEF3EB;">

    <!-- Layered sky-to-hills pastoral gradient -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 90% 50% at 50% 0%, #C8D8E8 0%, transparent 55%),
        radial-gradient(ellipse 60% 40% at 15% 30%, #E8F0E4 0%, transparent 55%),
        radial-gradient(ellipse 50% 35% at 85% 25%, #F0E8D8 0%, transparent 50%),
        linear-gradient(to bottom, #D4E4EC 0%, #E8EDE4 35%, #EEF3EB 60%, #D6E4CF 100%);
    "></div>

    <!-- Paper texture overlay -->
    <div class="absolute inset-0 pointer-events-none" style="
      background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E&quot;);
      opacity: 0.5;
      mix-blend-mode: multiply;
    "></div>

    <!-- Floating decorative botanical elements -->
    <!-- Leaf cluster top-left -->
    <div class="absolute top-12 left-6 md:left-20 opacity-60 animate-float" style="animation-delay: 0s;">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M24 44 C24 44 4 32 4 18 C4 10 12 4 24 8 C36 4 44 10 44 18 C44 32 24 44 24 44Z" fill="#5C7A4E" opacity="0.55"/>
        <path d="M24 8 L24 44" stroke="#4A6340" stroke-width="1.5" opacity="0.4"/>
        <path d="M24 18 C20 15 14 16 12 20" stroke="#4A6340" stroke-width="1" opacity="0.35"/>
        <path d="M24 28 C28 25 34 26 36 30" stroke="#4A6340" stroke-width="1" opacity="0.35"/>
      </svg>
    </div>
    <!-- Small bird / sparrow top-right -->
    <div class="absolute top-16 right-12 md:right-32 opacity-50 animate-float" style="animation-delay: 1.4s; font-size: 1.5rem;">🐦</div>
    <!-- Floating sprig center-right -->
    <div class="absolute top-1/3 right-6 md:right-16 opacity-40 animate-float" style="animation-delay: 0.7s; font-size: 2rem;">🌿</div>
    <!-- Sun top-right distant -->
    <div class="absolute top-8 right-1/3 opacity-30 animate-float" style="animation-delay: 2s; font-size: 1.8rem;">☀</div>
    <!-- Wildflower bottom-left -->
    <div class="absolute bottom-36 left-8 md:left-24 animate-float" style="animation-delay: 1.1s; opacity: 0.45;">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="18" cy="18" r="5" fill="#D4A843" opacity="0.8"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(0 18 18)"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(45 18 18)"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(90 18 18)"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(135 18 18)"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(180 18 18)"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(225 18 18)"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(270 18 18)"/>
        <ellipse cx="18" cy="8" rx="4" ry="7" fill="#C4735A" opacity="0.6" transform="rotate(315 18 18)"/>
      </svg>
    </div>
    <!-- Tiny sparkle / cross top-center -->
    <div class="absolute top-20 left-1/2 -translate-x-12 opacity-35" style="font-size: 1.2rem; color: #D4A843;">✦</div>
    <div class="absolute top-32 right-1/4 opacity-30" style="font-size: 1rem; color: #5C7A4E;">✿</div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-36 md:pt-28 md:pb-44 text-center">

      <!-- Tag pill -->
      <div class="inline-flex items-center gap-2 px-5 py-2 mb-8 animate-bounce-in"
           style="background: #F5EFE0; color: #5C7A4E; border: 1.5px solid #D9CEB2; border-radius: 10px; font-family: 'Caveat', cursive; font-size: 1.05rem; font-weight: 700; box-shadow: 0 2px 8px rgba(92,122,78,0.10);">
        ✿ Illustrated Printables for Homeschool Families
      </div>

      <!-- Headline -->
      <h1 class="animate-slide-up" style="font-family: 'Playfair Display', serif; font-weight: 900; font-size: clamp(2.8rem, 8vw, 5.5rem); line-height: 1.08; letter-spacing: -0.02em; color: #2F4A35;">
        School Around the<br>Kitchen Table
      </h1>
      <!-- Script subline — Caveat in dusty rose, hand-lettered feel -->
      <p class="animate-slide-up delay-100" style="font-family: 'Caveat', cursive; font-size: clamp(1.6rem, 4.5vw, 2.6rem); font-weight: 700; color: #C4735A; margin-top: 0.25em; line-height: 1.25;">
        where curious kids grow wild &amp; wonderful
      </p>

      <!-- Sub -->
      <p class="mt-7 max-w-xl mx-auto animate-slide-up delay-200"
         style="font-family: 'Lora', serif; font-style: italic; font-size: 1.1rem; line-height: 1.8; color: #5C5240;">
        Illustrated, print-ready curriculum packs for ages 3–12 — designed for the family that learns in muddy boots, at the farmhouse table, all five kids at once.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center animate-slide-up delay-300">
        <a href="#products"
           class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
           style="background: #5C7A4E; color: #F5EFE0; font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1rem; border-radius: 12px; box-shadow: 0 4px 18px rgba(92,122,78,0.28); min-height: 52px;">
          🧺 Shop the Packs
        </a>
        <a href="#cta"
           class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base transition-all duration-200 hover:bg-opacity-80 hover:-translate-y-0.5"
           style="background: #F5EFE0; border: 2px solid #D9CEB2; color: #2F4A35; font-family: 'Caveat', cursive; font-weight: 700; font-size: 1.15rem; border-radius: 12px; min-height: 52px;">
          Claim My Free Sampler ✿
        </a>
      </div>

      <!-- Social proof micro -->
      <div class="mt-10 flex flex-wrap justify-center gap-x-8 gap-y-3 animate-fade-in delay-400">
        <div class="flex items-center gap-2" style="color: #5C5240;">
          <span style="color: #D4A843; font-size: 1rem;">★★★★★</span>
          <span style="font-family: 'Lora', serif; font-size: 0.875rem;">Rated 4.9 by 2,000+ families</span>
        </div>
        <div class="flex items-center gap-2" style="color: #5C5240;">
          <span style="font-size: 1rem;">📥</span>
          <span style="font-family: 'Lora', serif; font-size: 0.875rem;">Instant PDF · Print forever</span>
        </div>
        <div class="flex items-center gap-2" style="color: #5C5240;">
          <span style="font-size: 1rem;">🌱</span>
          <span style="font-family: 'Lora', serif; font-size: 0.875rem;">No subscription · Yours to keep</span>
        </div>
      </div>
    </div>

    <!-- Rolling hills SVG bottom — multi-layered pastoral landscape -->
    <div class="absolute bottom-0 left-0 right-0" style="line-height: 0;">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:120px; display:block;">
        <!-- Distant hill — lightest sage -->
        <path d="M0 90 C120 55 280 80 440 62 C600 44 720 72 880 55 C1040 38 1180 68 1340 50 C1400 44 1430 56 1440 52 L1440 120 L0 120 Z" fill="#BACDB1" opacity="0.5"/>
        <!-- Mid hill — medium sage -->
        <path d="M0 105 C80 72 200 96 350 78 C500 60 640 90 800 72 C960 54 1100 84 1280 68 C1370 60 1420 78 1440 74 L1440 120 L0 120 Z" fill="#8DAF7D" opacity="0.6"/>
        <!-- Front hill — parchment (merges with next section) -->
        <path d="M0 115 C100 88 240 110 400 96 C560 82 700 108 860 94 C1020 80 1160 104 1320 92 C1390 87 1430 100 1440 96 L1440 120 L0 120 Z" fill="#F5EFE0"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       HOW IT WORKS — Parchment, 3-step process, botanical style
  ═══════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-20 md:py-28" style="background: #F5EFE0;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 mb-4" style="font-family: 'Caveat', cursive; font-size: 1.2rem; font-weight: 700; color: #5C7A4E;">
          Simple as 1-2-3 ✿
        </span>
        <h2 class="font-bold" style="font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); color: #2F4A35; letter-spacing: -0.01em;">
          From Shop to Schoolroom in Minutes
        </h2>
        <p class="mt-4 text-lg max-w-xl mx-auto" style="font-family: 'Lora', serif; color: #5C5240; line-height: 1.75;">
          No waiting for shipping. No membership gates. Just beautiful resources ready to print and use today.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <!-- Step 1 -->
        <div class="relative p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
             style="background: #FDFAF5; border: 1.5px solid #D9CEB2; border-radius: 14px; box-shadow: 0 2px 12px rgba(92,122,78,0.08);">
          <div class="w-16 h-16 rounded-full mx-auto mb-5 flex items-center justify-center text-3xl"
               style="background: #F0CEBF;">🧺</div>
          <div class="absolute -top-4 -right-4 w-10 h-10 rounded-full flex items-center justify-center font-bold text-white text-lg"
               style="background: #C4735A; font-family: 'Playfair Display', serif;">1</div>
          <h3 class="font-bold text-xl mb-3" style="font-family: 'Playfair Display', serif; color: #2F4A35;">Pick Your Pack</h3>
          <p class="text-base leading-relaxed" style="font-family: 'Lora', serif; color: #5C5240;">
            Browse by age, subject, or season. Every pack is illustrated and thoughtfully designed for real homeschool days.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
             style="background: #FDFAF5; border: 1.5px solid #D9CEB2; border-radius: 14px; box-shadow: 0 2px 12px rgba(92,122,78,0.08);">
          <div class="w-16 h-16 rounded-full mx-auto mb-5 flex items-center justify-center text-3xl"
               style="background: #D8EAF3;">📬</div>
          <div class="absolute -top-4 -right-4 w-10 h-10 rounded-full flex items-center justify-center font-bold text-white text-lg"
               style="background: #C4735A; font-family: 'Playfair Display', serif;">2</div>
          <h3 class="font-bold text-xl mb-3" style="font-family: 'Playfair Display', serif; color: #2F4A35;">Download Instantly</h3>
          <p class="text-base leading-relaxed" style="font-family: 'Lora', serif; color: #5C5240;">
            Checkout takes 60 seconds. Your PDF lands in your inbox right away — no account required, no waiting.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
             style="background: #FDFAF5; border: 1.5px solid #D9CEB2; border-radius: 14px; box-shadow: 0 2px 12px rgba(92,122,78,0.08);">
          <div class="w-16 h-16 rounded-full mx-auto mb-5 flex items-center justify-center text-3xl"
               style="background: #EEF3EB;">🖨️</div>
          <div class="absolute -top-4 -right-4 w-10 h-10 rounded-full flex items-center justify-center font-bold text-white text-lg"
               style="background: #C4735A; font-family: 'Playfair Display', serif;">3</div>
          <h3 class="font-bold text-xl mb-3" style="font-family: 'Playfair Display', serif; color: #2F4A35;">Print &amp; Learn!</h3>
          <p class="text-base leading-relaxed" style="font-family: 'Lora', serif; color: #5C5240;">
            Print at home or any copy shop. Re-print as many times as you need — it's yours to keep forever.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Gentle hills divider: parchment → sage-green products bg -->
  <div style="line-height: 0; display: block; background: #F5EFE0; margin-bottom: -2px;">
    <svg viewBox="0 0 1440 64" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:64px; display:block;">
      <path d="M0 0 C160 64 340 18 540 46 C720 72 900 22 1100 50 C1240 68 1360 28 1440 44 L1440 64 L0 64 Z" fill="#EEF3EB"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════
       PRODUCTS — Warm cream, illustrated cards, earthy borders
  ═══════════════════════════════════════════════════════════════════ -->
  <section id="products" style="background: #EEF3EB; position: relative; overflow: hidden;">

    <div class="py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 mb-4" style="font-family: 'Caveat', cursive; font-size: 1.2rem; font-weight: 700; color: #5C7A4E;">
            🌿 Curriculum Packs
          </span>
          <h2 class="font-bold" style="font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); color: #2F4A35; letter-spacing: -0.01em;">
            Learning That Feels Like Home
          </h2>
          <p class="mt-4 text-lg max-w-2xl mx-auto" style="font-family: 'Lora', serif; color: #5C5240; line-height: 1.75;">
            Each pack is age-leveled, faith-neutral, and full of activities kids actually want to sit down and do.
          </p>
        </div>

        <!-- Product Grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">

          <!-- Card 1 — Ocean Unit Study -->
          <div class="group relative overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl"
               style="background: #FDFAF5; border: 1.5px solid #D9CEB2; border-radius: 14px; box-shadow: 0 2px 14px rgba(92,122,78,0.09);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, #D8EAF3 0%, #B5D4E6 100%);">
              🌊
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 70% 30%, white 0%, transparent 60%);"></div>
              <!-- Age badge -->
              <div class="absolute top-3 right-3 px-2.5 py-1 text-xs font-bold text-white"
                   style="background: #C4735A; border-radius: 8px; font-family: 'Caveat', cursive; font-size: 0.9rem;">K-2</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-bold text-lg leading-snug" style="font-family: 'Playfair Display', serif; color: #2F4A35;">
                  Ocean World Unit Study
                </h3>
                <span class="shrink-0 font-bold" style="font-family: 'Playfair Display', serif; color: #5C7A4E;">$18</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="font-family: 'Lora', serif; color: #5C5240;">
                Dive deep into marine science with 40+ pages of games, crafts, reading passages, and math activities.
              </p>
              <a href="#cta" class="block text-center py-2.5 text-sm font-bold transition-all duration-200 hover:opacity-90"
                 style="background: #7BA7BC; color: white; border-radius: 10px; font-family: 'Playfair Display', serif;">
                Add to Cart →
              </a>
            </div>
          </div>

          <!-- Card 2 — Seasons Bundle (FEATURED) -->
          <div class="group relative overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl sm:scale-105 sm:-mt-2"
               style="background: #FDFAF5; border: 2px solid #5C7A4E; border-radius: 14px; box-shadow: 0 8px 32px rgba(92,122,78,0.18);">
            <!-- Best Seller ribbon -->
            <div class="absolute top-4 left-0 px-4 py-1.5 text-xs font-bold rounded-r-full z-10"
                 style="background: #5C7A4E; color: #F5EFE0; font-family: 'Caveat', cursive; font-size: 0.95rem;">
              ✦ Best Seller
            </div>
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, #EEF3EB 0%, #D6E4CF 100%);">
              🌸
              <div class="absolute inset-0 opacity-15" style="background: radial-gradient(circle at 30% 70%, white 0%, transparent 60%);"></div>
              <div class="absolute top-3 right-3 px-2.5 py-1 text-xs font-bold"
                   style="background: #5C7A4E; color: #F5EFE0; border-radius: 8px; font-family: 'Caveat', cursive; font-size: 0.9rem;">K-3</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-bold text-lg leading-snug" style="font-family: 'Playfair Display', serif; color: #2F4A35;">
                  Four Seasons Mega Bundle
                </h3>
                <div class="text-right shrink-0">
                  <span class="block text-xs line-through" style="color: #9E9070;">$72</span>
                  <span class="font-bold" style="font-family: 'Playfair Display', serif; color: #5C7A4E;">$39</span>
                </div>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="font-family: 'Lora', serif; color: #5C5240;">
                A full year of seasonal learning — 150+ pages across science, literacy, math, and art for every season.
              </p>
              <a href="#cta" class="block text-center py-2.5 text-sm font-bold transition-all duration-200 hover:opacity-90 hover:shadow-md"
                 style="background: #5C7A4E; color: #F5EFE0; border-radius: 10px; font-family: 'Playfair Display', serif;">
                Get the Bundle →
              </a>
            </div>
          </div>

          <!-- Card 3 — Alphabet Adventure -->
          <div class="group relative overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl"
               style="background: #FDFAF5; border: 1.5px solid #D9CEB2; border-radius: 14px; box-shadow: 0 2px 14px rgba(92,122,78,0.09);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, #F5E8C0 0%, #EDD394 100%);">
              🔤
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 50% 50%, white 0%, transparent 60%);"></div>
              <div class="absolute top-3 right-3 px-2.5 py-1 text-xs font-bold"
                   style="background: #C4735A; color: white; border-radius: 8px; font-family: 'Caveat', cursive; font-size: 0.9rem;">PreK</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-bold text-lg leading-snug" style="font-family: 'Playfair Display', serif; color: #2F4A35;">
                  Alphabet Adventure Pack
                </h3>
                <span class="shrink-0 font-bold" style="font-family: 'Playfair Display', serif; color: #5C7A4E;">$15</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="font-family: 'Lora', serif; color: #5C5240;">
                26 playful letter activities, tracing sheets, phonics games, and mini-books for early learners.
              </p>
              <a href="#cta" class="block text-center py-2.5 text-sm font-bold transition-all duration-200 hover:opacity-90"
                 style="background: #D4A843; color: #2F4A35; border-radius: 10px; font-family: 'Playfair Display', serif;">
                Add to Cart →
              </a>
            </div>
          </div>

          <!-- Card 4 — Rainforest -->
          <div class="group relative overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl"
               style="background: #FDFAF5; border: 1.5px solid #D9CEB2; border-radius: 14px; box-shadow: 0 2px 14px rgba(92,122,78,0.09);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, #D6E4CF 0%, #BACDB1 100%);">
              🦜
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 20% 80%, white 0%, transparent 60%);"></div>
              <div class="absolute top-3 right-3 px-2.5 py-1 text-xs font-bold"
                   style="background: #5C7A4E; color: #F5EFE0; border-radius: 8px; font-family: 'Caveat', cursive; font-size: 0.9rem;">Gr 2-4</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-bold text-lg leading-snug" style="font-family: 'Playfair Display', serif; color: #2F4A35;">
                  Rainforest Explorer Study
                </h3>
                <span class="shrink-0 font-bold" style="font-family: 'Playfair Display', serif; color: #5C7A4E;">$22</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="font-family: 'Lora', serif; color: #5C5240;">
                Explore ecosystems, animal adaptations, and geography through 50+ pages of hands-on work.
              </p>
              <a href="#cta" class="block text-center py-2.5 text-sm font-bold transition-all duration-200 hover:opacity-90"
                 style="background: #5C7A4E; color: #F5EFE0; border-radius: 10px; font-family: 'Playfair Display', serif;">
                Add to Cart →
              </a>
            </div>
          </div>

          <!-- Card 5 — Multiplication -->
          <div class="group relative overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl"
               style="background: #FDFAF5; border: 1.5px solid #D9CEB2; border-radius: 14px; box-shadow: 0 2px 14px rgba(92,122,78,0.09);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, #E5E2EF 0%, #C8C2DF 100%);">
              🔢
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 80% 20%, white 0%, transparent 60%);"></div>
              <div class="absolute top-3 right-3 px-2.5 py-1 text-xs font-bold"
                   style="background: #9B8EB5; color: white; border-radius: 8px; font-family: 'Caveat', cursive; font-size: 0.9rem;">Gr 3-5</div>
