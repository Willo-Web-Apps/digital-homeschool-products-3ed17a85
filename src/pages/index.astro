---
import Base from '../layouts/Base.astro';
---
<Base 
  title="Bright Nest Learning — Colorful Homeschool Curriculum &amp; Printables" 
  description="Beautiful, print-ready homeschool curriculum packs designed for curious kids aged 3–12. Download colorful unit studies, activity packs, and lesson bundles today."
>

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Coral gradient, warm and energizing
  ═══════════════════════════════════════════════════════════════════ -->
  <section class="hero-section relative overflow-hidden" style="background: oklch(0.60 0.18 25);">

    <!-- Layered gradient lighting -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 80% 60% at 10% 20%, oklch(0.72 0.18 50 / 0.55) 0%, transparent 65%),
        radial-gradient(ellipse 60% 50% at 90% 80%, oklch(0.85 0.17 85 / 0.35) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 70% 10%, oklch(0.72 0.12 185 / 0.20) 0%, transparent 50%),
        linear-gradient(155deg, oklch(0.58 0.19 22) 0%, oklch(0.62 0.17 30) 50%, oklch(0.68 0.16 40) 100%);
    "></div>

    <!-- Noise texture -->
    <div class="absolute inset-0 hero-noise" style="
      background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\");
      opacity: 0.04;
      mix-blend-mode: overlay;
      pointer-events: none;
    "></div>

    <!-- Decorative floating shapes -->
    <div class="absolute top-10 left-6 md:left-16 opacity-70 animate-float" style="animation-delay: 0s;">
      <div class="w-14 h-14 rounded-full" style="background: oklch(0.85 0.17 85 / 0.85);"></div>
    </div>
    <div class="absolute top-20 right-10 md:right-24 opacity-60 animate-float" style="animation-delay: 1.2s;">
      <div class="w-8 h-8 rounded-full" style="background: oklch(0.72 0.12 185 / 0.9);"></div>
    </div>
    <div class="absolute bottom-24 left-12 md:left-32 opacity-50 animate-float" style="animation-delay: 0.6s;">
      <div class="w-10 h-10 rounded-lg rotate-12" style="background: oklch(0.85 0.17 85 / 0.7);"></div>
    </div>
    <div class="absolute bottom-16 right-8 md:right-20 opacity-60 animate-float" style="animation-delay: 1.8s;">
      <div class="w-12 h-12 rounded-full" style="background: oklch(0.92 0.12 60 / 0.5);"></div>
    </div>
    <div class="absolute top-1/2 right-4 md:right-12 opacity-40 animate-float" style="animation-delay: 0.9s;">
      <div class="w-6 h-6 rounded-full" style="background: white;"></div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">

      <!-- Tag pill -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-6 animate-bounce-in"
           style="background: oklch(0.85 0.17 85); color: oklch(0.22 0.07 255);">
        <span>✨</span>
        <span>Digital Downloads for Homeschool Families</span>
      </div>

      <!-- Headline -->
      <h1 class="font-display font-bold leading-[1.1] tracking-tight animate-slide-up"
          style="font-size: clamp(2.6rem, 7vw, 4.5rem); color: white;">
        Beautiful Learning Materials<br>
        <span style="color: oklch(0.85 0.17 85);">Your Kids Will Beg to Use</span>
      </h1>

      <!-- Sub -->
      <p class="mt-6 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto animate-slide-up delay-100"
         style="color: oklch(0.98 0.01 30 / 0.90); font-family: var(--font-body);">
        Colorful, print-ready homeschool curriculum packs designed for curious kids aged 3–12 — download and start today.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center animate-slide-up delay-200">
        <a href="#products"
           class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl text-base font-semibold font-display transition-all duration-200 hover:scale-105 hover:shadow-xl"
           style="background: oklch(0.85 0.17 85); color: oklch(0.22 0.07 255); box-shadow: 0 4px 20px oklch(0.85 0.17 85 / 0.4);">
          🛒 Shop the Store
        </a>
        <a href="#how-it-works"
           class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl text-base font-semibold font-display transition-all duration-200 hover:scale-105"
           style="background: white / 0.15; border: 2px solid white; color: white; backdrop-filter: blur(8px); background-color: rgba(255,255,255,0.15);">
          See How It Works →
        </a>
      </div>

      <!-- Social proof micro -->
      <div class="mt-10 flex flex-wrap justify-center gap-6 animate-fade-in delay-400">
        <div class="flex items-center gap-2" style="color: oklch(0.98 0.01 30 / 0.85);">
          <span class="text-xl">⭐</span>
          <span class="text-sm font-semibold font-body">4.9/5 from 2,000+ families</span>
        </div>
        <div class="flex items-center gap-2" style="color: oklch(0.98 0.01 30 / 0.85);">
          <span class="text-xl">📥</span>
          <span class="text-sm font-semibold font-body">Instant digital download</span>
        </div>
        <div class="flex items-center gap-2" style="color: oklch(0.98 0.01 30 / 0.85);">
          <span class="text-xl">🖨️</span>
          <span class="text-sm font-semibold font-body">Print as many times as you need</span>
        </div>
      </div>
    </div>

    <!-- Wave divider bottom -->
    <div class="absolute bottom-0 left-0 right-0 leading-none" style="line-height: 0;">
      <svg viewBox="0 0 1440 56" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:56px; display:block;">
        <path d="M0 56 C240 20 480 56 720 36 C960 16 1200 52 1440 28 L1440 56 L0 56 Z" fill="oklch(0.985 0.012 60)"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       HOW IT WORKS — Warm cream, 3-step process
  ═══════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-20 md:py-28" style="background: oklch(0.985 0.012 60);">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold font-display mb-4"
              style="background: oklch(0.93 0.05 25); color: oklch(0.50 0.18 25);">
          Simple as 1-2-3
        </span>
        <h2 class="font-display font-bold" style="font-size: clamp(2rem, 5vw, 3rem); color: oklch(0.22 0.07 255);">
          From Shop to Schoolroom in Minutes
        </h2>
        <p class="mt-4 text-lg max-w-xl mx-auto" style="color: oklch(0.40 0.04 60); font-family: var(--font-body);">
          No waiting for shipping. No membership gates. Just instant, beautiful resources ready to print.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <!-- Step 1 -->
        <div class="relative rounded-3xl p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
             style="background: white; border: 2px solid oklch(0.93 0.020 60);">
          <div class="w-16 h-16 rounded-2xl mx-auto mb-5 flex items-center justify-center text-3xl"
               style="background: oklch(0.93 0.05 25);">🛍️</div>
          <div class="absolute -top-4 -right-4 w-10 h-10 rounded-full flex items-center justify-center font-display font-bold text-white text-lg"
               style="background: oklch(0.60 0.18 25);">1</div>
          <h3 class="font-display font-semibold text-xl mb-3" style="color: oklch(0.22 0.07 255);">Pick Your Pack</h3>
          <p class="text-base leading-relaxed" style="color: oklch(0.45 0.04 60); font-family: var(--font-body);">
            Browse by age, subject, or season. Every pack is beautifully designed and curriculum-aligned.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative rounded-3xl p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
             style="background: white; border: 2px solid oklch(0.93 0.020 60);">
          <div class="w-16 h-16 rounded-2xl mx-auto mb-5 flex items-center justify-center text-3xl"
               style="background: oklch(0.95 0.07 85);">⚡</div>
          <div class="absolute -top-4 -right-4 w-10 h-10 rounded-full flex items-center justify-center font-display font-bold text-white text-lg"
               style="background: oklch(0.78 0.17 85); color: oklch(0.22 0.07 255);">2</div>
          <h3 class="font-display font-semibold text-xl mb-3" style="color: oklch(0.22 0.07 255);">Download Instantly</h3>
          <p class="text-base leading-relaxed" style="color: oklch(0.45 0.04 60); font-family: var(--font-body);">
            Checkout takes 60 seconds. Your PDF arrives in your inbox immediately — no account required.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative rounded-3xl p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
             style="background: white; border: 2px solid oklch(0.93 0.020 60);">
          <div class="w-16 h-16 rounded-2xl mx-auto mb-5 flex items-center justify-center text-3xl"
               style="background: oklch(0.92 0.06 185);">🖨️</div>
          <div class="absolute -top-4 -right-4 w-10 h-10 rounded-full flex items-center justify-center font-display font-bold text-white text-lg"
               style="background: oklch(0.72 0.12 185);">3</div>
          <h3 class="font-display font-semibold text-xl mb-3" style="color: oklch(0.22 0.07 255);">Print &amp; Play!</h3>
          <p class="text-base leading-relaxed" style="color: oklch(0.45 0.04 60); font-family: var(--font-body);">
            Print at home or at any copy shop. Re-print anytime — it's yours forever.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       PRODUCTS — Colorful grid on cream, with sticker-badge cards
  ═══════════════════════════════════════════════════════════════════ -->
  <section id="products" style="background: oklch(0.97 0.018 60); position: relative; overflow: hidden;">

    <!-- Top wave -->
    <div class="leading-none" style="line-height: 0; margin-top: -2px;">
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:40px; display:block;">
        <path d="M0 0 C360 40 1080 0 1440 30 L1440 0 L0 0 Z" fill="oklch(0.985 0.012 60)"/>
      </svg>
    </div>

    <div class="py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold font-display mb-4"
                style="background: oklch(0.92 0.06 185); color: oklch(0.44 0.12 185);">
            🎒 Curriculum Packs
          </span>
          <h2 class="font-display font-bold" style="font-size: clamp(2rem, 5vw, 3rem); color: oklch(0.22 0.07 255);">
            Learning That Looks as Good as It Feels
          </h2>
          <p class="mt-4 text-lg max-w-2xl mx-auto" style="color: oklch(0.40 0.04 60); font-family: var(--font-body);">
            Every pack is secular-friendly, age-leveled, and stuffed with activities kids actually want to do.
          </p>
        </div>

        <!-- Product Grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">

          <!-- Card 1 — Ocean Unit Study -->
          <div class="group relative rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
               style="background: white; border: 2px solid oklch(0.93 0.020 60);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, oklch(0.92 0.06 185) 0%, oklch(0.85 0.08 210) 100%);">
              🌊
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 70% 30%, white 0%, transparent 60%);"></div>
              <!-- Sticker badge -->
              <div class="absolute -top-2 -right-2 w-14 h-14 rounded-full flex items-center justify-center text-xl font-display font-bold shadow-lg"
                   style="background: oklch(0.85 0.17 85); color: oklch(0.22 0.07 255);">K-2</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-display font-semibold text-lg leading-snug" style="color: oklch(0.22 0.07 255);">
                  Ocean World Unit Study
                </h3>
                <span class="shrink-0 text-base font-display font-bold" style="color: oklch(0.60 0.18 25);">$18</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: oklch(0.48 0.04 60); font-family: var(--font-body);">
                Dive deep into marine science with 40+ pages of games, crafts, reading passages, and math activities.
              </p>
              <a href="#cta" class="block text-center py-2.5 rounded-xl font-display font-semibold text-sm transition-all duration-200 hover:shadow-md"
                 style="background: oklch(0.72 0.12 185); color: white;">
                Add to Cart →
              </a>
            </div>
          </div>

          <!-- Card 2 — Seasons Bundle (FEATURED) -->
          <div class="group relative rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl sm:scale-105 sm:-mt-2"
               style="background: white; border: 3px solid oklch(0.60 0.18 25); box-shadow: 0 8px 40px oklch(0.60 0.18 25 / 0.15);">
            <!-- Best Seller ribbon -->
            <div class="absolute top-5 left-0 px-4 py-1.5 text-xs font-display font-bold rounded-r-full z-10"
                 style="background: oklch(0.60 0.18 25); color: white;">
              ⭐ Best Seller
            </div>
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, oklch(0.93 0.05 25) 0%, oklch(0.92 0.08 50) 100%);">
              🌸
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 30% 70%, white 0%, transparent 60%);"></div>
              <div class="absolute -top-2 -right-2 w-14 h-14 rounded-full flex items-center justify-center text-xl font-display font-bold shadow-lg"
                   style="background: oklch(0.60 0.18 25); color: white;">K-3</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-display font-semibold text-lg leading-snug" style="color: oklch(0.22 0.07 255);">
                  Four Seasons Mega Bundle
                </h3>
                <div class="text-right shrink-0">
                  <span class="block text-xs line-through" style="color: oklch(0.60 0.04 60);">$72</span>
                  <span class="text-base font-display font-bold" style="color: oklch(0.60 0.18 25);">$39</span>
                </div>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: oklch(0.48 0.04 60); font-family: var(--font-body);">
                A full year of seasonal learning — 150+ pages across science, literacy, math, and art for every season.
              </p>
              <a href="#cta" class="block text-center py-2.5 rounded-xl font-display font-semibold text-sm transition-all duration-200 hover:shadow-md hover:scale-105"
                 style="background: oklch(0.60 0.18 25); color: white;">
                Get the Bundle →
              </a>
            </div>
          </div>

          <!-- Card 3 — Alphabet Adventure -->
          <div class="group relative rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
               style="background: white; border: 2px solid oklch(0.93 0.020 60);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, oklch(0.95 0.07 85) 0%, oklch(0.90 0.10 70) 100%);">
              🔤
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 50% 50%, white 0%, transparent 60%);"></div>
              <div class="absolute -top-2 -right-2 w-14 h-14 rounded-full flex items-center justify-center text-xl font-display font-bold shadow-lg"
                   style="background: oklch(0.85 0.17 85); color: oklch(0.22 0.07 255);">PreK</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-display font-semibold text-lg leading-snug" style="color: oklch(0.22 0.07 255);">
                  Alphabet Adventure Pack
                </h3>
                <span class="shrink-0 text-base font-display font-bold" style="color: oklch(0.60 0.18 25);">$15</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: oklch(0.48 0.04 60); font-family: var(--font-body);">
                26 playful letter activities, tracing sheets, phonics games, and mini-books for early learners.
              </p>
              <a href="#cta" class="block text-center py-2.5 rounded-xl font-display font-semibold text-sm transition-all duration-200 hover:shadow-md"
                 style="background: oklch(0.85 0.17 85); color: oklch(0.22 0.07 255);">
                Add to Cart →
              </a>
            </div>
          </div>

          <!-- Card 4 — Rainforest -->
          <div class="group relative rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
               style="background: white; border: 2px solid oklch(0.93 0.020 60);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, oklch(0.90 0.10 145) 0%, oklch(0.85 0.10 165) 100%);">
              🦜
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 20% 80%, white 0%, transparent 60%);"></div>
              <div class="absolute -top-2 -right-2 w-14 h-14 rounded-full flex items-center justify-center text-xl font-display font-bold shadow-lg"
                   style="background: oklch(0.72 0.12 185); color: white;">Gr 2-4</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-display font-semibold text-lg leading-snug" style="color: oklch(0.22 0.07 255);">
                  Rainforest Explorer Study
                </h3>
                <span class="shrink-0 text-base font-display font-bold" style="color: oklch(0.60 0.18 25);">$22</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: oklch(0.48 0.04 60); font-family: var(--font-body);">
                Explore ecosystems, animal adaptations, and geography through 50+ colorful pages of hands-on work.
              </p>
              <a href="#cta" class="block text-center py-2.5 rounded-xl font-display font-semibold text-sm transition-all duration-200 hover:shadow-md"
                 style="background: oklch(0.64 0.12 185); color: white;">
                Add to Cart →
              </a>
            </div>
          </div>

          <!-- Card 5 — Multiplication -->
          <div class="group relative rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
               style="background: white; border: 2px solid oklch(0.93 0.020 60);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, oklch(0.93 0.06 280) 0%, oklch(0.88 0.10 295) 100%);">
              🔢
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 80% 20%, white 0%, transparent 60%);"></div>
              <div class="absolute -top-2 -right-2 w-14 h-14 rounded-full flex items-center justify-center text-xl font-display font-bold shadow-lg"
                   style="background: oklch(0.85 0.17 85); color: oklch(0.22 0.07 255);">Gr 3-5</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-display font-semibold text-lg leading-snug" style="color: oklch(0.22 0.07 255);">
                  Multiplication Mastery Kit
                </h3>
                <span class="shrink-0 text-base font-display font-bold" style="color: oklch(0.60 0.18 25);">$19</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: oklch(0.48 0.04 60); font-family: var(--font-body);">
                Games, skip-counting songs, visual arrays, and practice sheets that make times tables click — finally.
              </p>
              <a href="#cta" class="block text-center py-2.5 rounded-xl font-display font-semibold text-sm transition-all duration-200 hover:shadow-md"
                 style="background: oklch(0.55 0.14 280); color: white;">
                Add to Cart →
              </a>
            </div>
          </div>

          <!-- Card 6 — Space Unit -->
          <div class="group relative rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
               style="background: white; border: 2px solid oklch(0.93 0.020 60);">
            <div class="h-44 flex items-center justify-center text-6xl relative overflow-hidden"
                 style="background: linear-gradient(135deg, oklch(0.88 0.07 240) 0%, oklch(0.82 0.10 255) 100%);">
              🚀
              <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 60% 40%, white 0%, transparent 60%);"></div>
              <div class="absolute -top-2 -right-2 w-14 h-14 rounded-full flex items-center justify-center text-xl font-display font-bold shadow-lg"
                   style="background: oklch(0.60 0.18 25); color: white;">Gr 4-6</div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-display font-semibold text-lg leading-snug" style="color: oklch(0.22 0.07 255);">
                  Space &amp; Solar System Pack
                </h3>
                <span class="shrink-0 text-base font-display font-bold" style="color: oklch(0.60 0.18 25);">$24</span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: oklch(0.48 0.04 60); font-family: var(--font-body);">
                Planets, constellations, moon phases, and astronaut biographies — 60+ pages of stellar learning.
              </p>
              <a href="#cta" class="block text-center py-2.5 rounded-xl font-display font-semibold text-sm transition-all duration-200 hover:shadow-md"
                 style="background: oklch(0.44 0.13 255); color: white;">
                Add to Cart →
              </a>
            </div>
          </div>

        </div>

        <!-- View all link -->
        <div class="text-center mt-12">
          <a href="#cta" class="inline-flex items-center gap-2 text-base font-display font-semibold transition-all duration-200 hover:gap-3"
             style="color: oklch(0.60 0.18 25);">
            Browse all 40+ packs in the shop
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

      </div>
    </div>

    <!-- Bottom wave into teal -->
    <div class="leading-none" style="line-height: 0;">
