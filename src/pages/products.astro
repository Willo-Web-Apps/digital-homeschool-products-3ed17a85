---
import Base from '../layouts/Base.astro';
import EmailCapture from '../components/EmailCapture.astro';

const chartImageUrl = "https://kufdcnvteecdsgfbxbyn.supabase.co/storage/v1/object/public/business-assets/a5f8640e-aaef-4165-ab7b-bccea5660286/images/customary-metric-units-chart-2ea76655.jpg";

const products = [
  {
    id: "customary-metric-chart",
    title: "Customary & Metric Units Reference Chart",
    subtitle: "Instant Digital Download · Printable PDF",
    price: "$3.99",
    badge: "🏆 Best Seller",
    badgeColor: "#E8533A",
    image: chartImageUrl,
    description: "A beautifully organized, color-coded reference chart covering ALL the measurement units your homeschooler needs — from length and capacity to weight and temperature. Perfect for math lessons, science units, and hanging on the learning wall!",
    features: [
      "✅ Customary AND Metric units side-by-side",
      "✅ Length, Capacity, Weight & Temperature",
      "✅ Conversion cross-reference section",
      "✅ Color-coded by category for easy learning",
      "✅ Print-ready PDF — 8.5×11 format",
      "✅ Works for grades 3–8",
    ],
    checkoutUrl: "#coming-soon",
    comingSoon: true,
  }
];
---
<Base title="Shop Digital Products — Homegrown" description="Colorful, print-ready homeschool printables and reference charts. Instant digital downloads for homeschool families.">

  <!-- Page Hero -->
  <section style="background: linear-gradient(135deg, oklch(0.97 0.04 80) 0%, oklch(0.96 0.06 50) 50%, oklch(0.97 0.05 200) 100%); border-bottom: 3px solid oklch(0.60 0.18 25)20;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold mb-6"
           style="background: white; color: oklch(0.60 0.18 25); border: 2px solid oklch(0.60 0.18 25);">
        🛍️ Digital Downloads Shop
      </div>
      <h1 class="font-display font-extrabold text-4xl sm:text-5xl leading-tight mb-4"
          style="color: oklch(0.22 0.07 255);">
        Learn With Color &amp; Joy 🌈
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: oklch(0.40 0.04 60);">
        Instant-download printables designed to make learning stick. Colorful, curriculum-aligned, and ready to print in seconds.
      </p>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    {products.map((product) => (
      <div class="group bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 max-w-4xl mx-auto mb-12"
           style="border: 2px solid oklch(0.92 0.03 60);">
        <div class="md:flex">

          <!-- Product Image -->
          <div class="md:w-2/5 relative overflow-hidden" style="background: oklch(0.97 0.02 80);">
            <div class="absolute top-4 left-4 z-10">
              <span class="inline-block px-3 py-1.5 rounded-full text-xs font-bold text-white shadow-md"
                    style={`background: ${product.badgeColor};`}>
                {product.badge}
              </span>
            </div>
            <img
              src={product.image}
              alt={product.title}
              class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              style="min-height: 320px; max-height: 480px;"
            />
          </div>

          <!-- Product Details -->
          <div class="md:w-3/5 p-8 flex flex-col justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: oklch(0.60 0.18 25);">
                {product.subtitle}
              </p>
              <h2 class="font-display font-extrabold text-2xl sm:text-3xl leading-tight mb-4"
                  style="color: oklch(0.22 0.07 255);">
                {product.title}
              </h2>
              <p class="text-base leading-relaxed mb-6" style="color: oklch(0.40 0.04 60);">
                {product.description}
              </p>

              <!-- Features List -->
              <ul class="space-y-2 mb-8">
                {product.features.map((f) => (
                  <li class="text-sm font-medium" style="color: oklch(0.35 0.04 60);">{f}</li>
                ))}
              </ul>
            </div>

            <!-- Price + CTA -->
            <div class="flex items-center gap-4 flex-wrap">
              <span class="font-display font-extrabold text-4xl" style="color: oklch(0.22 0.07 255);">
                {product.price}
              </span>

              {product.comingSoon ? (
                <div class="flex flex-col gap-2 flex-1">
                  <div class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-2xl font-display font-bold text-lg text-white w-full transition-all"
                       style="background: linear-gradient(135deg, oklch(0.60 0.18 25), oklch(0.70 0.20 50)); opacity: 0.8; cursor: not-allowed;">
                    🔒 Payments Coming Soon
                  </div>
                  <p class="text-xs text-center" style="color: oklch(0.55 0.04 60);">
                    Connect Stripe in your dashboard to enable purchases
                  </p>
                </div>
              ) : (
                <a href={product.checkoutUrl}
                   class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-2xl font-display font-bold text-lg text-white flex-1 hover:scale-105 hover:shadow-lg transition-all duration-200"
                   style="background: linear-gradient(135deg, oklch(0.60 0.18 25), oklch(0.70 0.20 50));">
                  🛒 Buy Now — {product.price}
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- More products coming soon card -->
    <div class="max-w-4xl mx-auto rounded-3xl p-12 text-center"
         style="background: linear-gradient(135deg, oklch(0.97 0.06 200) 0%, oklch(0.97 0.05 280) 100%); border: 2px dashed oklch(0.75 0.12 200);">
      <div class="text-5xl mb-4">🚀</div>
      <h3 class="font-display font-bold text-2xl mb-2" style="color: oklch(0.22 0.07 255);">
        More Products Coming Soon!
      </h3>
      <p class="mb-6" style="color: oklch(0.40 0.04 60);">
        We're adding new printables every week. Join the list to be first to know!
      </p>
      <div class="max-w-md mx-auto">
        <EmailCapture source="products-page" />
      </div>
    </div>

  </section>

  <!-- Trust Section -->
  <section style="background: oklch(0.22 0.07 255);" class="py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-display font-bold text-white text-lg mb-8">Why Homegrown families love our printables</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        {[
          { icon: "⚡", title: "Instant Download", desc: "Print within seconds of purchase" },
          { icon: "🎨", title: "Color-Coded", desc: "Visual design that helps kids remember" },
          { icon: "📐", title: "Curriculum-Aligned", desc: "Matches common homeschool standards" },
        ].map((item) => (
          <div class="flex flex-col items-center gap-3">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl"
                 style="background: rgba(255,255,255,0.15);">
              {item.icon}
            </div>
            <h4 class="font-display font-bold text-white">{item.title}</h4>
            <p class="text-sm" style="color: rgba(255,255,255,0.7);">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
